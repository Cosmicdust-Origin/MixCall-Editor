generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id         String       @id
  nickname   String?
  createdAt  DateTime     @default(now())
  callSheets CallSheet[]
  mixPresets MixPreset[]
  comments   Comment[]
  bookmarks Bookmark[]
  likes Like[]
}

model Artist {
  id        String   @id @default(cuid())
  name      String
  nameKo    String?
  nameJp    String?
  createdAt DateTime @default(now())
  songs     Song[]
}

model Song {
  id         String      @id @default(cuid())
  artistId   String
  artist     Artist      @relation(fields: [artistId], references: [id])
  title      String
  titleKo    String?
  createdAt  DateTime    @default(now())
  callSheets CallSheet[]
}

model CallSheet {
  id          String    @id @default(cuid())
  userId      String
  user        Profile   @relation(fields: [userId], references: [id])
  songId      String?
  song        Song?     @relation(fields: [songId], references: [id])
  artistName  String?
  songTitle   String?
  isPublic    Boolean   @default(false)
  blocks      Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    Comment[]
  bookmarks Bookmark[]
  likes Like[]
}

model MixPreset {
  id         String   @id @default(cuid())
  userId     String?
  user       Profile? @relation(fields: [userId], references: [id])
  name       String
  category   String
  bars       Int?
  tokens     String[]
  text       String
  isOfficial Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Comment {
  id        String    @id @default(cuid())
  sheetId   String
  sheet     CallSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  userId    String
  user      Profile   @relation(fields: [userId], references: [id])
  parentId  String?
  parent    Comment?  @relation("replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("replies")
  content   String
  createdAt DateTime  @default(now())
}

model Like {
  id        String    @id @default(cuid())
  sheetId   String
  sheet     CallSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  userId    String
  user      Profile   @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())

  @@unique([sheetId, userId])
}

model Bookmark {
  id        String    @id @default(cuid())
  sheetId   String
  sheet     CallSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  userId    String
  user      Profile   @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())

  @@unique([sheetId, userId])
}

songLang    String?   // 'ko' | 'jp'